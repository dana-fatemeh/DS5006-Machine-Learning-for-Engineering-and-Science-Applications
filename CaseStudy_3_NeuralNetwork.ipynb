            "epoch:  220 training loss: 4.516e+04 time:    2.6\n",
            "epoch:  240 training loss: 4.285e+04 time:    2.9\n",
            "epoch:  260 training loss: 4.220e+04 time:    3.2\n",
            "epoch:  280 training loss: 4.521e+04 time:    3.6\n",
            "epoch:  300 training loss: 4.427e+04 time:    3.9\n",
